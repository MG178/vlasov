<Window x:Class="FastDelivery.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FastDelivery - Вход" Height="430" Width="560"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" MinHeight="430" MinWidth="560">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*"/>
            <ColumnDefinition Width="0.9*"/>
        </Grid.ColumnDefinitions>

        <Border Margin="16" CornerRadius="20" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="FastDelivery" Foreground="White" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="MVP для автоматизации курьерской доставки" Foreground="#D4F1EE" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,14,0,0">
                    <TextBlock Text="Что доступно в проекте:" Foreground="White" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
                    <TextBlock Text="• заказы по ролям" Foreground="White" FontSize="15" LineHeight="28" TextWrapping="Wrap"/>
                    <TextBlock Text="• назначения курьеров" Foreground="White" FontSize="15" LineHeight="28" TextWrapping="Wrap"/>
                    <TextBlock Text="• каталоги зон и тарифов" Foreground="White" FontSize="15" LineHeight="28" TextWrapping="Wrap"/>
                    <TextBlock Text="• отчеты и уведомления" Foreground="White" FontSize="15" LineHeight="28" TextWrapping="Wrap"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="MVP PROJECT" Foreground="#C5F0EB" FontSize="12"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Margin="8,16,16,16" Background="{StaticResource SurfaceBrush}" CornerRadius="18" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Вход в систему" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,14"/>

                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <TextBlock Text="Логин"/>
                    <TextBox x:Name="LoginBox" Height="34"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,8">
                    <TextBlock Text="Пароль"/>
                    <PasswordBox x:Name="PasswordBox" Height="34"/>
                </StackPanel>

                <TextBlock Grid.Row="3" x:Name="ErrorText" Foreground="#B91C1C" TextWrapping="Wrap" Margin="4,2,4,10"/>

                <Button Grid.Row="4" Content="Войти" HorizontalAlignment="Stretch" Height="38" Click="Login_Click"/>

            </Grid>
        </Border>
    </Grid>
</Window>
